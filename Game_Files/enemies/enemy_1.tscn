[sub_resource type="GDScript" id="GDScript_gwy4j"]
script/source = "extends AnimatedSprite2D
const Gravity = 800
const speed = 70
var direction = 1
# Called when the node enters the scene tree for the first time.
@onready var RayCastleft: RayCast2D = $RayCast2D
@onready var RayCastright: RayCast2D = $RayCast2D2
@onready var timer: Timer = $Area2D/Timer
@onready var enemy: AnimatedSprite2D = $\".\"

func _process(delta) -> void:
	if RayCastleft.is_colliding():
		direction = 1
		enemy.flip_H = true
	if RayCastright.is_colliding():
		direction = -1
	position.x += direction * speed * delta
	enemy.flip_H = false
"

